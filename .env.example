# Server
PORT=5000
NODE_ENV=development

# MongoDB Atlas connection string
MONGO_URI= your_mongo_uri

# JWT
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=7d

# Invite tokens (signed separately so they can have a shorter lifetime)
INVITE_SECRET=replace_with_another_long_random_secret
INVITE_EXPIRES_IN=2d
